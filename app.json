{
  "expo": {
    "name": "Erick",
    "slug": "erick-photo-editor",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "erick",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.erick.photoeditor",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Erick needs camera access to take photos for editing.",
        "NSPhotoLibraryUsageDescription": "Erick needs access to your photo library to select images for editing.",
        "NSPhotoLibraryAddUsageDescription": "Erick saves edited photos to your library.",
        "NSMicrophoneUsageDescription": "Erick needs microphone access for video recording.",
        "NSFaceIDUsageDescription": "Use Face ID to securely access your account."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0A0A0F"
      },
      "package": "com.erick.photoeditor",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE", 
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.VIBRATE",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.POST_NOTIFICATIONS",
        "com.android.vending.BILLING"
      ],
      "googleServicesFile": "./google-services.json",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "erickphotoeditor.app"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        },
        {
          "action": "SEND",
          "data": [{ "mimeType": "image/*" }],
          "category": ["DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Erick to access your camera to take photos for editing."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Erick to access your photos for editing.",
          "cameraPermission": "Allow Erick to use your camera to take photos."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Erick to save edited photos to your library.",
          "savePhotosPermission": "Allow Erick to save photos to your library.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#7C3AED"
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      "@react-native-firebase/crashlytics"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "your-eas-project-id"
      }
    }
  }
}
